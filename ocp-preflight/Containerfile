FROM registry.access.redhat.com/ubi9/ubi-minimal:latest

LABEL name="ickis" \
      summary="Ickis — OCP Installation Pre-flight Validator" \
      description="Scaring up install problems before they scare you" \
      maintainer="pkhedeka@redhat.com"

ARG GOVC_VERSION=0.37.3

RUN microdnf install -y \
        bind-utils \
        nmap-ncat \
        nmap \
        python3 \
        python3-pyyaml \
        openssl \
        curl \
        iputils \
        iproute \
        tar \
        gzip \
    --nodocs && microdnf clean all

RUN curl -sL "https://github.com/vmware/govmomi/releases/download/v${GOVC_VERSION}/govc_Linux_x86_64.tar.gz" | \
    tar -xz -C /usr/local/bin govc && \
    chmod +x /usr/local/bin/govc

COPY . /opt/ickis/
RUN chmod +x /opt/ickis/ickis.sh

WORKDIR /workspace

ENTRYPOINT ["/opt/ickis/ickis.sh"]
